<Prefab>
  <Constants />
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>

        <!-- Slot 0 -->
        <Widget IsVisible="@Slot0Visible"
                WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                SuggestedWidth="62" SuggestedHeight="72"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                MarginLeft="@Slot0PosX" MarginTop="@Slot0PosY">
          <Children>
            <!-- Gold ring (shown when currently controlled) -->
            <Widget IsVisible="@Slot0Current"
                    WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                    SuggestedWidth="62" SuggestedHeight="62"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Sprite="BlankWhiteCircle" Color="#C8A84BFF" />
            <!-- Dark circle backing -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                    SuggestedWidth="56" SuggestedHeight="56"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    MarginTop="3"
                    Sprite="BlankWhiteCircle" Color="#1A1A1AFF" />
            <!-- Portrait -->
            <ImageIdentifierWidget DataSource="{Slot0Portrait}"
                                   WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                   SuggestedWidth="56" SuggestedHeight="56"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   MarginTop="3"
                                   ImageId="@Id" AdditionalArgs="@AdditionalArgs"
                                   IsVisible="@IsValid"
                                   TextureProviderName="@TextureProviderName" />
            <!-- Downward arrow -->
            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Text="▼" Brush="CompanionHotswap.Arrow.Gold" />
          </Children>
        </Widget>

