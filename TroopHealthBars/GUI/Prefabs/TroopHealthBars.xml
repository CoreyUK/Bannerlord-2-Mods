                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                            SuggestedWidth="286" SuggestedHeight="19"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            MarginLeft="32"
                            Sprite="BlankWhiteSquare_9" Color="#0A0805F0" />
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                            SuggestedWidth="282" SuggestedHeight="15"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            MarginLeft="34"
                            Sprite="BlankWhiteSquare_9" Color="#6F5A34FF" />
