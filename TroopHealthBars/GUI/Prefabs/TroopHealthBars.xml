                            Sprite="StdAssets\arrow_pointing_left" HorizontalFlip="true" Color="#160D08FF" />

                    <FillBar WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                             SuggestedWidth="270" SuggestedHeight="7"
                             HorizontalAlignment="Left" VerticalAlignment="Center"
                             MarginLeft="40"
                             Brush="TroopHealthBars.HealthBar"
                             IsVisible="@UseBannerlordRed"
