<Brushes>
  <Brush Name="LoadoutPresets.Header.Text" FontSize="18" Font="FiraSansExtraCondensed-Regular">
    <Styles>
      <Style Name="Default" FontColor="#FFFFFFFF" TextOutlineColor="#000000FF" TextOutlineAmount="0.6" TextHorizontalAlignment="Center" TextVerticalAlignment="Center" />
    </Styles>
  </Brush>

  <Brush Name="LoadoutPresets.Slot.Text" FontSize="24" Font="FiraSansExtraCondensed-Regular">
    <Styles>
      <Style Name="Default" FontColor="#FFFFFFFF" TextOutlineColor="#000000FF" TextOutlineAmount="0.6" TextHorizontalAlignment="Center" TextVerticalAlignment="Center" />
    </Styles>
  </Brush>

  <Brush Name="LoadoutPresets.Save.Text" FontSize="14" Font="FiraSansExtraCondensed-Regular">
    <Styles>
      <Style Name="Default" FontColor="#FFFFFFFF" TextOutlineColor="#000000FF" TextOutlineAmount="0.5" TextHorizontalAlignment="Center" TextVerticalAlignment="Center" />
    </Styles>
  </Brush>

  <Brush Name="LoadoutPresets.Status.Text" FontSize="13" Font="FiraSansExtraCondensed-Regular">
    <Styles>
      <Style Name="Default" FontColor="#D8D8D8FF" TextOutlineColor="#000000FF" TextOutlineAmount="0.5" TextHorizontalAlignment="Center" TextVerticalAlignment="Center" />
    </Styles>
  </Brush>

  <Brush Name="LoadoutPresets.Toggle.Text" FontSize="22" Font="FiraSansExtraCondensed-Regular">
