      <Style Name="Default" FontColor="#FFFFFFFF" TextOutlineColor="#000000FF" TextOutlineAmount="0.6" TextHorizontalAlignment="Center" TextVerticalAlignment="Center" />
    </Styles>
  </Brush>

  <Brush Name="LoadoutPresets.Slot.Button" TransitionDuration="0.12">
    <Layers>
      <BrushLayer Name="Default" Sprite="Inventory\ShieldIcon" Color="#FFFFFFFF" />
      <BrushLayer Name="Hover" Sprite="Inventory\ShieldIcon" Color="#F4D56FFF" />
      <BrushLayer Name="Pressed" Sprite="Inventory\ShieldIcon" Color="#C8A84BFF" />
    </Layers>
  </Brush>

  <Brush Name="LoadoutPresets.Save.Button" TransitionDuration="0.12">
    <Layers>
      <BrushLayer Name="Default" Sprite="button_canvas_9" OverlayMethod="CoverWithTexture" OverlaySprite="button_marble" Color="#FFFFFFFF" />
      <BrushLayer Name="Overlay" Sprite="button_frame_9" />
      <BrushLayer Name="Hover" Sprite="button_canvas_9" OverlayMethod="CoverWithTexture" OverlaySprite="button_marble" Color="#F4D56FFF" />
    </Layers>
  </Brush>

  <Brush Name="LoadoutPresets.Toggle.Button" TransitionDuration="0.12">
    <Layers>
      <BrushLayer Name="Default" Sprite="button_canvas_9" OverlayMethod="CoverWithTexture" OverlaySprite="button_marble" Color="#FFFFFFFF" />
      <BrushLayer Name="Overlay" Sprite="button_frame_9" />
      <BrushLayer Name="Hover" Sprite="button_canvas_9" OverlayMethod="CoverWithTexture" OverlaySprite="button_marble" Color="#F4D56FFF" />
    </Layers>
